# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=sgi
POSTGRES_USER=sgi_user
POSTGRES_PASSWORD=change_me_in_production

# ── Valkey (Redis fork) ─────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ── MinIO ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=sgi-media

# ── Meilisearch ─────────────────────────────────────────────────────────
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=change_me_in_production

# ── FastAPI ─────────────────────────────────────────────────────────────
SECRET_KEY=change_me_in_production_min_32_chars
API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── JWT ─────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRE_HOURS=8
JWT_REFRESH_EXPIRE_DAYS=30

# ── Google Maps ─────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── WhatsApp Business ───────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── Email (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@sgi.ae
SMTP_PASSWORD=change_me_in_production

# ── Sentry ──────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Next.js public ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key
