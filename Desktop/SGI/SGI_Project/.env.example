# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=sgi
# Rôle privilégié (superuser/propriétaire) — migrations + worker Celery.
POSTGRES_USER=sgi_user
POSTGRES_PASSWORD=change_me_in_production

# Rôle applicatif RESTREINT (C1) — utilisé par les requêtes API pour que la RLS
# multi-tenant s'applique réellement (sgi_app : NOSUPERUSER, NOBYPASSRLS).
# Si APP_DB_PASSWORD est vide, l'API retombe sur le rôle privilégié et la RLS
# n'est PAS appliquée. À définir en prod ; le rôle est créé par la migration 0022.
APP_DB_USER=sgi_app
APP_DB_PASSWORD=change_me_app_role_in_production

# ── Valkey (Redis fork) ─────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ── MinIO ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
# Endpoint PUBLIC pour la présignature (joignable par le navigateur). En dev : localhost:9000.
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=sgi-media

# ── Meilisearch ─────────────────────────────────────────────────────────
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=change_me_in_production

# ── Observabilité (Admin Console · serveurs/réseau) ──────────────────────
# URL de base Prometheus, lue par app/routers/admin/prometheus.py pour l'état
# live des serveurs et les métriques réseau. Laisser vide = dégradation propre
# (« métriques indisponibles », pas d'erreur). Live dès que la stack monitoring
# (docker-compose.monitoring.yml) tourne sur le même réseau.
PROMETHEUS_URL=http://prometheus:9090

# ── Contrôle serveurs (Admin Console · D2 — HAUT RISQUE) ─────────────────
# Active l'EXÉCUTION RÉELLE des actions start/stop/restart/pause. Défaut false →
# dry-run (action seulement journalisée). Mettre true UNIQUEMENT avec le profil
# compose "control" (docker compose --profile control up) qui démarre le worker-infra
# isolé + le docker-socket-proxy. Sans ce profil, l'action restera "requested".
INFRA_CONTROL_ENABLED=false
# URL TCP du docker-socket-proxy (lue par le worker-infra uniquement).
DOCKER_PROXY_URL=http://docker-socket-proxy:2375

# ── Backups (Admin Console · déclenchement) ──────────────────────────────
# Active l'exécution RÉELLE du déclenchement de sauvegarde (pg_dump). Défaut false
# → dry-run (backup_run journalisé sans exécution). Non destructif. Requiert le binaire
# `pg_dump` (postgresql-client) dans l'image worker pour l'exécution réelle.
BACKUP_TRIGGER_ENABLED=false
# Répertoire cible des sauvegardes dans le worker.
BACKUP_DIR=/backups

# ── FastAPI ─────────────────────────────────────────────────────────────
SECRET_KEY=change_me_in_production_min_32_chars
API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── JWT ─────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRE_HOURS=1     # 60 min — access court ; la session 30 j tient via le refresh token
JWT_REFRESH_EXPIRE_DAYS=30    # durée de vie du refresh token (cookie sgi-refresh + table refresh_tokens)

# ── Google Maps ─────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Gemini (parsing IA des besoins client) ──────────────────────────────
# Clé GRATUITE via https://aistudio.google.com/apikey (free-tier : ~20-1500
# requêtes/jour selon le projet). Si absente OU quota dépassé → repli
# automatique sur le parseur heuristique local (aucune panne).
# ⚠️ Free-tier : Google peut utiliser les données pour l'entraînement.
# Pour de la prod avec PII client, activer la facturation (pay-per-use).
GEMINI_API_KEY=your_gemini_api_key
# Modèle (optionnel) : gemini-2.5-flash (défaut) | gemini-2.5-flash-lite | ...
GEMINI_MODEL=gemini-2.5-flash

# ── TTS Azure Speech — voix d'avatar des scénarios vidéo (optionnel) ─────────
# Si vide, la voix d'avatar est désactivée (diaporama silencieux) ; le mode
# « voix enregistrée » fonctionne sans. Voix ar-AE (Hamdan/Fatima) pour l'arabe
# du Golfe, + EN/FR selon la langue détectée du script.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=uaenorth

# ── WhatsApp Business ───────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── WhatsApp webhook (inbound, Inbox omnicanal) ──────────────────────────
# Secret de vérification du challenge Meta (GET) et app secret pour la
# signature X-Hub-Signature-256 (POST). En PROD : définir le secret ET passer
# WHATSAPP_REQUIRE_SIGNATURE=true → tout payload non signé est rejeté
# (fail-closed). En dev (false) : best-effort si le secret est absent.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_REQUIRE_SIGNATURE=false
# Routage tenant : préférer l'enrôlement via POST /api/v1/inbox/channels
# (table inbox_channel_configs). Le mapping ci-dessous est un fallback déprécié.
# JSON : {"<phone_number_id>": "<company_uuid>"}
WHATSAPP_PHONE_NUMBER_MAP=

# ── Email (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@sgi.ae
SMTP_PASSWORD=change_me_in_production

# ── Sentry ──────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Téléphonie / Asterisk ────────────────────────────────────────────────
# AMI : consommé par l'API (module telephony, phase 2). Le secret doit matcher
# celui injecté dans manager.conf côté Asterisk (via $AMI_PASSWORD au démarrage).
AMI_HOST=asterisk
AMI_PORT=5038
AMI_USER=sgi-api
AMI_PASSWORD=change_me_in_production
# Technologie de canal : "PJSIP" (Asterisk >=12, dev dockerisé) ou "SIP"
# (Asterisk 11 / chan_sip → canal SIP/<ext>). Voir infra/asterisk/ASTERISK11_INTEGRATION.md
TELEPHONY_CHANNEL_TECH=PJSIP
# Contexte du dialplan pour l'Originate (click-to-call). "internal" en dev ;
# sur un Asterisk réel, le contexte qui sait joindre l'extérieur (ex. from-internal).
TELEPHONY_ORIGINATE_CONTEXT=internal
# CN du certificat TLS auto-signé généré pour le WSS (dev).
ASTERISK_TLS_CN=asterisk.sgi.local
# PDPL : présumer le consentement d'enregistrement pour les appels créés par
# l'AMI ? false en prod (fail-closed, pas d'upload sans consentement positif) ;
# true en dev pour activer l'enregistrement automatique.
TELEPHONY_ASSUME_RECORDING_CONSENT=false

# ── Next.js public ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key
# URL WebSocket WSS du softphone web (JsSIP). En dev, le navigateur tape localhost.
NEXT_PUBLIC_SIP_WS_URL=wss://localhost:8089/ws
# Base WS du backend telephony (events d'appel / screen pop). Optionnel : à
# défaut le front utilise la même origine (nginx proxifie /api/v1). Ex. dev :
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
