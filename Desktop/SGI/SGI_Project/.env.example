# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=sgi
POSTGRES_USER=sgi_user
POSTGRES_PASSWORD=change_me_in_production

# ── Valkey (Redis fork) ─────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ── MinIO ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=sgi-media

# ── Meilisearch ─────────────────────────────────────────────────────────
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=change_me_in_production

# ── FastAPI ─────────────────────────────────────────────────────────────
SECRET_KEY=change_me_in_production_min_32_chars
API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── JWT ─────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRE_HOURS=8
JWT_REFRESH_EXPIRE_DAYS=30

# ── Google Maps ─────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Agenda Real Estate (Google Calendar) ────────────────────────────────
# ID/email du calendrier partagé, ex. equipe@group.calendar.google.com
GOOGLE_CALENDAR_SRC=
AGENDA_TIMEZONE=Asia/Dubai

# ── Gemini (parsing IA des besoins client) ──────────────────────────────
# Clé GRATUITE via https://aistudio.google.com/apikey (free-tier : ~20-1500
# requêtes/jour selon le projet). Si absente OU quota dépassé → repli
# automatique sur le parseur heuristique local (aucune panne).
# ⚠️ Free-tier : Google peut utiliser les données pour l'entraînement.
# Pour de la prod avec PII client, activer la facturation (pay-per-use).
GEMINI_API_KEY=your_gemini_api_key
# Modèle (optionnel) : gemini-2.5-flash (défaut) | gemini-2.5-flash-lite | ...
GEMINI_MODEL=gemini-2.5-flash

# ── WhatsApp Business ───────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── Email (SMTP) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@sgi.ae
SMTP_PASSWORD=change_me_in_production

# ── Sentry ──────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Next.js public ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key
# ID du calendrier Google affiché dans Real Estate › Agenda (back-office)
NEXT_PUBLIC_GOOGLE_CALENDAR_SRC=equipe@group.calendar.google.com
