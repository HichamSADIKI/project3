# API endpoint (change for production)
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1

# App environment
EXPO_PUBLIC_APP_ENV=development

# ─── Social login — Google OAuth ──────────────────────────────────────────────
# Créer un projet sur https://console.cloud.google.com/ → OAuth consent screen
# → Identifiants → OAuth Client ID (un par plateforme).
#   - iOS     : bundle id = com.infinity-uae.sgi
#   - Android : package = com.infinityuae.sgi + SHA-1 de la clé de signature
#   - Web     : requis pour le mode Expo Go / proxy (useProxy=true)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ─── Social login — Apple ─────────────────────────────────────────────────────
# Pas de variable côté mobile : Sign in with Apple s'active via
# `ios.usesAppleSignIn=true` dans app.json + capability "Sign In with Apple"
# activée sur l'App ID dans le portail Apple Developer.
# Côté backend, fournir APPLE_SERVICE_ID / APPLE_TEAM_ID / APPLE_KEY_ID
# pour vérifier les identityToken via appleid.apple.com/auth/keys.
